---
import EditionLayout from '../../../layouts/EditionLayout.astro';
import { editionStaticPaths, editionTitle, type ResolvedEdition } from '../../../data/editions';
import { useTranslations, type Lang } from '../../../i18n/utils';

export const getStaticPaths = editionStaticPaths;

const { r } = Astro.props as { r: ResolvedEdition };
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const heading = editionTitle(r);
const { email, name } = r.contact;
---

<EditionLayout lang={lang} r={r} active="contato" title={`${t('nav.contact')} · ${heading}`}>
  <h2>{t('nav.contact')}</h2>
  <p class="lead">{t('edition.contact.lead')}</p>

  <div class="card">
    {name && <p class="name">{name}</p>}
    <a class="email" href={`mailto:${email}`}>{email}</a>
  </div>
</EditionLayout>

<style>
  h2 {
    font-size: 26px;
    margin: 0 0 12px;
  }
  .lead {
    color: var(--muted);
    max-width: 60ch;
    margin: 0 0 24px;
  }
  .card {
    display: inline-block;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 24px 28px;
    box-shadow: var(--shadow-card);
  }
  .name {
    margin: 0 0 6px;
    font-weight: 600;
    color: var(--ink);
  }
  .email {
    font-family: var(--font-mono);
    font-size: 15px;
    color: var(--accent);
  }
</style>
