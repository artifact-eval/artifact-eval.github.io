---
import EditionLayout from '../../../layouts/EditionLayout.astro';
import { editionStaticPaths, editionTitle, type ResolvedEdition, type ResultRow } from '../../../data/editions';
import { seals as sealDefs } from '../../../data/events';
import { useTranslations, type Lang } from '../../../i18n/utils';

export const getStaticPaths = editionStaticPaths;

const { r } = Astro.props as { r: ResolvedEdition };
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const heading = editionTitle(r);
const rows = r.data.results;
const docs = r.data.documents;
const intro = r.data.intro;
const hasContent = rows.length > 0 || docs.length > 0;
const hasLink = rows.some((row) => row.link);
const base = import.meta.env.BASE_URL; // e.g. "/" — keeps doc hrefs base-safe

// Group by track (preserving first-seen order); null track → single unlabeled group.
const order: (string | null)[] = [];
const byTrack = new Map<string | null, ResultRow[]>();
for (const row of rows) {
  const key = row.track;
  if (!byTrack.has(key)) {
    byTrack.set(key, []);
    order.push(key);
  }
  byTrack.get(key)!.push(row);
}
const grouped = order.map((key) => ({ track: key, rows: byTrack.get(key)! }));

// Group documents by their source section (preserving first-seen order).
const docOrder: (string | null)[] = [];
const docBySection = new Map<string | null, typeof docs>();
for (const d of docs) {
  const key = d.section;
  if (!docBySection.has(key)) {
    docBySection.set(key, []);
    docOrder.push(key);
  }
  docBySection.get(key)!.push(d);
}
const docGroups = docOrder.map((key) => ({ section: key, items: docBySection.get(key)! }));
const docHref = (href: string) => `${base}${href.replace(/^\//, '')}`;
const sealColor: Record<string, string> = { D: 'var(--seal-d)', F: 'var(--seal-f)', S: 'var(--seal-s)', R: 'var(--seal-r)' };

// Localized labels for canonical track codes; unknown codes fall back to the raw string.
const trackLabels: Record<Lang, Record<string, string>> = {
  pt: { TP: 'Trilha Principal (TP)', SF: 'Salão de Ferramentas (SF)', WTICG: 'WTICG' },
  en: { TP: 'Main Track (TP)', SF: 'Tools Track (SF)', WTICG: 'WTICG' },
  es: { TP: 'Pista Principal (TP)', SF: 'Salón de Herramientas (SF)', WTICG: 'WTICG' },
};
const trackLabel = (key: string | null): string | null => (key ? (trackLabels[lang][key] ?? key) : null);
---

<EditionLayout lang={lang} r={r} active="resultados" title={`${t('nav.results')} · ${heading}`}>
  <h2>{t('nav.results')}</h2>

  {
    !hasContent ? (
      <p class="tbd">{t('results.tbd')}</p>
    ) : (
      <>
        <p class="intro">{intro ?? t('results.intro')}</p>
        {grouped.map((group) => (
          <section class="group">
            {group.track && <h3>{trackLabel(group.track)}</h3>}
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th class="th-seals" scope="col">
                      <span class="seal-head">
                        {sealDefs.map((s) => (
                          <abbr title={t(`seal.${s.key}` as const)}>{s.key}</abbr>
                        ))}
                      </span>
                    </th>
                    <th scope="col">{t('results.col.work')}</th>
                    {hasLink && <th scope="col">{t('results.col.link')}</th>}
                  </tr>
                </thead>
                <tbody>
                  {group.rows.map((row) => (
                    <tr>
                      <td class="seals-cell">
                        {sealDefs.map((s) => (
                          <span
                            class:list={['mini', { off: !row.seals[s.key as 'D' | 'F' | 'S' | 'R'] }]}
                            style={`--c:${sealColor[s.key]}`}
                            title={t(`seal.${s.key}` as const)}
                          >
                            {s.key}
                          </span>
                        ))}
                      </td>
                      <td class="work">{row.title}</td>
                      {hasLink && (
                        <td class="link">
                          {row.link && (
                            <a href={row.link} target="_blank" rel="noopener">
                              {t('results.col.link')} ↗
                            </a>
                          )}
                        </td>
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        ))}
        {docs.length > 0 && (
          <section class="docs">
            <h3>{t('results.docs')}</h3>
            {docGroups.map((g) => (
              <div class="doc-group">
                {g.section && <h4>{g.section}</h4>}
                <ul class="doc-list">
                  {g.items.map((d) => (
                    <li>
                      <a href={docHref(d.href)} target="_blank" rel="noopener">
                        {d.label} ↗
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </section>
        )}
      </>
    )
  }
</EditionLayout>

<style>
  h2 {
    font-size: 26px;
    margin: 0 0 8px;
  }
  .intro {
    color: var(--muted);
    margin: 0 0 24px;
  }
  .tbd {
    color: var(--muted-2);
    font-style: italic;
  }
  .group {
    margin-bottom: 36px;
  }
  .group h3 {
    font-size: 16px;
    margin: 0 0 12px;
    color: var(--ink);
  }
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: var(--r-md);
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  thead th {
    text-align: left;
    background: var(--surface-3);
    color: var(--muted);
    font-weight: 700;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 12px 16px;
    white-space: nowrap;
  }
  tbody td {
    padding: 12px 16px;
    border-top: 1px solid var(--line);
    vertical-align: top;
  }
  tbody tr:hover {
    background: var(--surface-2);
  }
  .seal-head {
    display: inline-flex;
    gap: 6px;
  }
  .seal-head abbr {
    width: 20px;
    text-align: center;
    text-decoration: none;
    cursor: help;
  }
  .seals-cell {
    white-space: nowrap;
  }
  .mini {
    display: inline-grid;
    place-items: center;
    width: 22px;
    height: 22px;
    margin-right: 4px;
    border-radius: 6px;
    background: var(--c);
    color: #fff;
    font-size: 11px;
    font-weight: 800;
  }
  .mini.off {
    background: transparent;
    color: var(--line-2);
    box-shadow: inset 0 0 0 1.5px var(--line-2);
  }
  .work {
    min-width: 280px;
  }
  .link a {
    white-space: nowrap;
    font-weight: 600;
  }
  .docs {
    margin-top: 8px;
  }
  .docs > h3 {
    font-size: 18px;
    margin: 0 0 16px;
    color: var(--ink);
  }
  .doc-group {
    margin-bottom: 20px;
  }
  .doc-group h4 {
    font-size: 14px;
    margin: 0 0 8px;
    color: var(--muted);
    font-weight: 700;
  }
  .doc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 6px;
  }
  .doc-list a {
    font-weight: 600;
  }
</style>
