---
import EditionLayout from '../../../layouts/EditionLayout.astro';
import { editionStaticPaths, editionTitle, type ResolvedEdition } from '../../../data/editions';
import { useTranslations, type Lang } from '../../../i18n/utils';

export const getStaticPaths = editionStaticPaths;

const { r } = Astro.props as { r: ResolvedEdition };
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const heading = editionTitle(r);
const isTbd = (members: string[]) => members.length === 1 && /tbd/i.test(members[0]);

// Committee group names are stored in Portuguese in the edition data, so they
// bypass the i18n layer. Translate the known group names for EN/ES pages.
const groupNames: Record<string, { en: string; es: string }> = {
  'Coordenadores do CTA': { en: 'CTA Coordinators', es: 'Coordinadores del CTA' },
  'Coordenadores do CTA e CTAA': {
    en: 'CTA and CTAA Coordinators',
    es: 'Coordinadores del CTA y CTAA',
  },
  'Comitê Técnico de Artefatos (CTA)': {
    en: 'Artifact Technical Committee (CTA)',
    es: 'Comité Técnico de Artefactos (CTA)',
  },
  'Comitê Técnico Auxiliar de Artefatos (CTAA)': {
    en: 'Auxiliary Artifact Technical Committee (CTAA)',
    es: 'Comité Técnico Auxiliar de Artefactos (CTAA)',
  },
  'Comitê de Seleção de Artefatos (CTA)': {
    en: 'Artifact Selection Committee (CTA)',
    es: 'Comité de Selección de Artefactos (CTA)',
  },
  'Melhores Revisores do CTA': {
    en: 'CTA Best Reviewers',
    es: 'Mejores Revisores del CTA',
  },
  Tutores: { en: 'Tutors', es: 'Tutores' },
  'Selo Design': { en: 'Design Badge', es: 'Sello Diseño' },
};

const groupName = (group: string): string =>
  lang === 'pt' ? group : (groupNames[group]?.[lang as 'en' | 'es'] ?? group);

// The "best reviewers" group only makes sense once names are defined; hide it
// while it is still a placeholder (TBD).
const isBestReviewers = (group: string) => /melhores revisores/i.test(group);
const groups = r.data.committee.filter(
  (g) => !(isBestReviewers(g.group) && isTbd(g.members)),
);
---

<EditionLayout lang={lang} r={r} active="comite" title={`${t('nav.committee')} · ${heading}`}>
  <h2>{t('nav.committee')}</h2>

  {
    groups.length === 0 ? (
      <p class="tbd">{t('committee.tbd')}</p>
    ) : (
      <div class="groups">
        {groups.map((g) => (
          <section class="group">
            <h3>{groupName(g.group)}</h3>
            {isTbd(g.members) ? (
              <p class="tbd">{t('committee.tbd')}</p>
            ) : (
              <ul>
                {g.members.map((m) => (
                  <li>{m}</li>
                ))}
              </ul>
            )}
          </section>
        ))}
      </div>
    )
  }
</EditionLayout>

<style>
  h2 {
    font-size: 26px;
    margin: 0 0 24px;
  }
  .groups {
    display: grid;
    gap: 32px;
  }
  .group h3 {
    font-size: 18px;
    margin: 0 0 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--line);
  }
  .group ul {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 2;
    column-gap: 32px;
    font-size: 15px;
    color: var(--ink-2);
  }
  .group li {
    padding: 4px 0;
    break-inside: avoid;
  }
  .tbd {
    color: var(--muted-2);
    font-style: italic;
  }
  @media (max-width: 640px) {
    .group ul {
      columns: 1;
    }
  }
</style>
