---
import Base from '../../layouts/Base.astro';
import Seals from '../../components/Seals.astro';
import EventCard from '../../components/EventCard.astro';
import { events } from '../../data/events';
import { localizePath, useTranslations, langOrder, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return langOrder.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---

<Base lang={lang}>
  <section class="hero">
    <div class="container">
      <span class="pill">{t('site.tagline')}</span>
      <h1>{t('home.hero.title')}</h1>
      <p class="lead">{t('home.hero.lead')}</p>
      <Seals lang={lang} />
    </div>
  </section>

  <section class="sect">
    <div class="container">
      <h2 class="sect__title">{t('home.events.title')}</h2>
      <div class="events">
        {events.map((event) => <EventCard event={event} lang={lang} />)}
      </div>

      <a class="callout" href={localizePath(lang, 'instrucoes')}>
        <span class="callout__text">
          <strong>{t('home.callout.title')}</strong> — {t('home.callout.body')}
        </span>
        <span class="callout__btn">{t('home.callout.cta')} →</span>
      </a>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: var(--hero-bg);
    padding-block: clamp(40px, 7vw, 56px);
  }
  .pill {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-soft);
    border-radius: var(--r-pill);
    padding: 6px 14px;
  }
  .hero h1 {
    font-size: clamp(34px, 6vw, 44px);
    letter-spacing: -0.01em;
    max-width: 16ch;
    margin: 18px 0 0;
  }
  .lead {
    font-size: clamp(15px, 2.5vw, 17px);
    color: var(--muted);
    max-width: 58ch;
    margin: 16px 0 0;
  }
  .hero :global(.seals) {
    margin-top: 30px;
  }

  .sect {
    padding-block: clamp(36px, 6vw, 44px);
  }
  .sect__title {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-2);
    margin: 0 0 22px;
  }
  .events {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .callout {
    margin-top: 22px;
    border-radius: var(--r-lg);
    padding: 26px 28px;
    display: flex;
    align-items: center;
    gap: 18px;
    background: linear-gradient(120deg, var(--ink), #27306b);
    color: #dfe6f5;
    text-decoration: none;
  }
  .callout:hover {
    text-decoration: none;
  }
  .callout strong {
    color: #fff;
  }
  .callout__btn {
    margin-left: auto;
    background: #fff;
    color: var(--ink);
    border-radius: var(--r-pill);
    padding: 11px 20px;
    font-size: 14px;
    font-weight: 700;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .events {
      grid-template-columns: 1fr;
    }
    .callout {
      flex-direction: column;
      align-items: flex-start;
    }
    .callout__btn {
      margin-left: 0;
    }
  }
</style>
