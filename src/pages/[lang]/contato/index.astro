---
import Base from '../../../layouts/Base.astro';
import { COMMITTEE_EMAIL } from '../../../data/editions';
import { useTranslations, langOrder, type Lang } from '../../../i18n/utils';

export async function getStaticPaths() {
  return langOrder.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---

<Base lang={lang} title={t('nav.contact')}>
  <section class="head">
    <div class="container">
      <h1>{t('nav.contact')}</h1>
      <p class="lead">{t('cta.contact.lead')}</p>
    </div>
  </section>

  <section class="container body">
    <div class="card">
      <p class="name">{t('site.title')} (CTA)</p>
      <a class="email" href={`mailto:${COMMITTEE_EMAIL}`}>{COMMITTEE_EMAIL}</a>
    </div>
  </section>
</Base>

<style>
  .head {
    background: var(--hero-bg);
    padding-block: clamp(32px, 5vw, 48px);
  }
  .head h1 {
    font-size: clamp(28px, 5vw, 38px);
    margin: 0;
  }
  .lead {
    color: var(--muted);
    max-width: 60ch;
    margin: 14px 0 0;
    font-size: 16px;
    line-height: 1.6;
  }
  .body {
    padding-block: clamp(28px, 5vw, 40px);
  }
  .card {
    display: inline-block;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 24px 28px;
    box-shadow: var(--shadow-card);
  }
  .name {
    font-weight: 600;
    margin: 0 0 8px;
  }
  .email {
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
  }
  .email:hover {
    text-decoration: underline;
  }
</style>
