---
import Base from '../../../layouts/Base.astro';
import { latestYear, getYearSections, instructionYears } from '../../../data/instructions';
import { localizePath, useTranslations, langOrder, type Lang } from '../../../i18n/utils';

export function getStaticPaths() {
  return langOrder.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const year = await latestYear(lang);
const sections = await getYearSections(lang, year);
const years = await instructionYears(lang);
const olderYears = years.filter((y) => y !== year);
---

<Base lang={lang} title={t('nav.instructions')}>
  <section class="head">
    <div class="container">
      <span class="pill">{year}</span>
      <h1>{t('nav.instructions')}</h1>
      <p class="lead">{t('home.callout.body')}</p>
    </div>
  </section>

  <section class="container body">
    <ul class="cards">
      {
        sections.map((s) => (
          <li>
            <a class="card" href={localizePath(lang, 'instrucoes', String(year), s.data.section)}>
              <h2>{s.data.title}</h2>
              <p>{s.data.summary}</p>
              <span class="more">→</span>
            </a>
          </li>
        ))
      }
    </ul>

    {
      olderYears.length > 0 && (
        <div class="archive">
          <h3>{lang === 'pt' ? 'Edições anteriores' : lang === 'es' ? 'Ediciones anteriores' : 'Previous years'}</h3>
          <ul class="years">
            {olderYears.map((y) => (
              <li>
                <a href={localizePath(lang, 'instrucoes', String(y))}>{y}</a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>
</Base>

<style>
  .head {
    background: var(--hero-bg);
    padding-block: clamp(36px, 6vw, 52px);
  }
  .pill {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-soft);
    border-radius: var(--r-pill);
    padding: 6px 14px;
  }
  .head h1 {
    font-size: clamp(30px, 5vw, 40px);
    margin: 16px 0 0;
  }
  .lead {
    color: var(--muted);
    max-width: 60ch;
    margin: 12px 0 0;
  }
  .body {
    padding-block: clamp(32px, 5vw, 44px);
  }
  .cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 18px;
  }
  .card {
    display: block;
    position: relative;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 24px 26px;
    box-shadow: var(--shadow-card);
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .card:hover {
    text-decoration: none;
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .card h2 {
    font-size: 20px;
    margin: 0 0 6px;
  }
  .card p {
    color: var(--muted);
    margin: 0;
    font-size: 14.5px;
    max-width: 62ch;
  }
  .card .more {
    position: absolute;
    top: 24px;
    right: 26px;
    color: var(--accent);
    font-weight: 700;
  }
  .archive {
    margin-top: 40px;
  }
  .archive h3 {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-2);
    margin: 0 0 12px;
  }
  .years {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0;
    padding: 0;
  }
  .years a {
    display: inline-block;
    font-weight: 600;
    font-size: 14px;
    padding: 7px 14px;
    border-radius: var(--r-pill);
    background: var(--surface-3);
    color: var(--ink-2);
    text-decoration: none;
  }
</style>
